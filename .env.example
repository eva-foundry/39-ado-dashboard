# ─── 39-ado-dashboard environment variables ───────────────────────────────────
# Copy this file to .env and fill in values before running locally.
# Do NOT commit .env to source control.
# Generated: 2026-02-20 10:55 ET

# ─── APIM (17-apim marco-sandbox-apim) ────────────────────────────────────────
# Base URL for the APIM gateway — no trailing slash
VITE_APIM_BASE_URL=https://marco-sandbox-apim.azure-api.net

# APIM subscription key (Ocp-Apim-Subscription-Key header)
VITE_APIM_SUBSCRIPTION_KEY=<your-apim-subscription-key>

# ─── Data Model API (37-data-model, Session 26 enhancements) ──────────────────
# Base URL for evidence-based velocity metrics — no trailing slash
# Default: Production cloud deployment
VITE_DATA_MODEL_BASE_URL=https://msub-eva-data-model.victoriousgrass-30debbd3.canadacentral.azurecontainerapps.io

# ─── eva-brain backend env vars (for scrum.py, used in 33-eva-brain-v2) ───────
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>
COSMOS_DATABASE=eva-foundation

ADO_ORG_URL=https://dev.azure.com/GCDigital
ADO_PROJECT=EVA
ADO_PAT=<your-ado-personal-access-token>
ADO_EPIC_ID=4
